<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_edit_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Perfil"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_edit_name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_edit_title">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_edit_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre completo" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_edit_phone"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/til_edit_name">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_edit_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:hint="Teléfono" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tv_map_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ubicación de Entrega Predeterminada"
        android:textColor="@color/secondary"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/til_edit_phone"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_location_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ubicación: No establecida"
        android:textColor="@color/secondary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_map_title" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_change_location"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Actualizar Ubicación en el Mapa"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_location_status" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_edit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Guardar Cambios"
        app:backgroundTint="@color/accent"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btn_change_location"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_reset_pwd_edit"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Solicitar Cambio de Contraseña"
        android:textColor="@color/secondary"
        app:strokeColor="@color/secondary"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btn_save_edit"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_delete_account"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Eliminar mi cuenta"
        android:textColor="#F44336"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btn_reset_pwd_edit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
