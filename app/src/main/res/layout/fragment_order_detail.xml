<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_order_detail"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="Detalle del Pedido"
            app:titleTextColor="@color/white"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Información General -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:id="@+id/tv_detail_order_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        tools:text="Pedido: #ABC12345" />

                    <TextView
                        android:id="@+id/tv_detail_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        tools:text="Estado: SOLICITADO" />

                    <TextView
                        android:id="@+id/tv_detail_payment_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textStyle="bold"
                        tools:text="Pago: Pendiente" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Cliente y Entrega -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Información del Cliente y Entrega"
                        android:textStyle="bold"
                        android:textColor="@color/secondary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_detail_client_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:text="Cliente: Cargando..." />

                    <TextView
                        android:id="@+id/tv_detail_client_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        tools:text="Teléfono: Cargando..." />

                    <TextView
                        android:id="@+id/tv_detail_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        tools:text="Domicilio: Lat 19.4, Lng -99.1" />

                    <TextView
                        android:id="@+id/tv_detail_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        tools:text="Fecha Entrega: 12/12/2026 14:00" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Finanzas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Resumen Financiero"
                        android:textStyle="bold"
                        android:textColor="@color/secondary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_detail_gross"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:text="Subtotal: $1500.00" />
                        
                    <TextView
                        android:id="@+id/tv_detail_discount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        tools:text="Descuento Fijo: $0.00" />

                    <TextView
                        android:id="@+id/tv_detail_net"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textStyle="bold"
                        tools:text="Total a Pagar: $1500.00" />

                    <TextView
                        android:id="@+id/tv_detail_paid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/primary"
                        tools:text="Abonado: $500.00" />

                    <TextView
                        android:id="@+id/tv_detail_debt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textStyle="bold"
                        android:textColor="@color/error"
                        tools:text="Deuda: $1000.00" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Productos List -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Productos a Distribuir"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/secondary"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_detail_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false" />

            <!-- Admin Action Buttons (Hidden by default) -->
            <LinearLayout
                android:id="@+id/layout_admin_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Acciones de Administrador"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_admin_abonar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Abonar Dinero" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_admin_liquidar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Liquidar Pedido (Pago Total)"
                    app:backgroundTint="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_admin_descuento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aplicar Descuento Fijo"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_admin_enviar_nota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enviar Nota (PDF)"
                    android:layout_marginTop="8dp"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconGravity="textStart"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>

            <!-- Botón para cancelar pedido (Visible para ambos) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_order"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancelar Pedido"
                android:layout_marginTop="16dp"
                android:textColor="@color/white"
                app:backgroundTint="@color/error" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
